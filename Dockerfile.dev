# Development Dockerfile for Next.js with hot reload
# Usage: docker compose up (from web/ directory)

FROM node:22-bookworm-slim

WORKDIR /app

# Install dependencies (will be cached across rebuilds)
COPY package.json package-lock.json ./
RUN npm ci

# Copy source code (overridden by volume mount in docker-compose.yml)
COPY . .

# Expose Next.js dev server port
EXPOSE 3000

# Sync node_modules when package-lock.json changes (volume over /app/node_modules)
ENTRYPOINT ["sh", "./docker-entrypoint-dev.sh"]
