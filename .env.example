# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Auth0 Configuration (from Terraform outputs)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Auth0 secret for session encryption (generate with: openssl rand -base64 32)
AUTH0_SECRET=

# Base URL of your application
# Local: http://localhost:3000
# Production: https://avcd.ai
AUTH0_BASE_URL=http://localhost:3000

# Auth0 tenant issuer URL
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com

# Auth0 web application client ID (from terraform output auth0_web_client_id)
AUTH0_CLIENT_ID=

# Auth0 web application client secret (from terraform output auth0_web_client_secret)
AUTH0_CLIENT_SECRET=

# Auth0 API identifier (audience) for AVCD GraphQL API (from terraform output auth0_api_identifier)
AUTH0_AUDIENCE=https://dev.avcd.ai/

# OAuth scopes to request (default includes refresh token support)
AUTH0_SCOPE="openid profile email offline_access"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Auth0 MCP Client (Static - shown to users for Claude Desktop/Web)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# MCP Native App Client ID (from terraform output auth0_mcp_client_id)
# This is public and safe to expose - all users share this client ID
NEXT_PUBLIC_AUTH0_MCP_CLIENT_ID=

# MCP Server URL (public, shown to users)
NEXT_PUBLIC_MCP_SERVER_URL=https://dev.avcd.ai/mcp

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AVCD API Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Public-facing AVCD GraphQL API URL (used by frontend)
NEXT_PUBLIC_AVCD_API_URL=https://dev.avcd.ai/api

# Server-side API base URL for Next.js server actions (internal)
AVCD_API_URL=http://api:8000

# Finance page: mock fixtures (default, CI-safe) vs live GraphQL (`api`)
NEXT_PUBLIC_FINANCE_DATA_SOURCE=mock

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Environment
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=development
