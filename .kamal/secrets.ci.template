#!/usr/bin/env bash
set -euo pipefail

INFISICAL_DOMAIN="${INFISICAL_API_URL%/api}"
INFISICAL_ENV_SLUG="${INFISICAL_ENV:-dev}"

export_dotenv() {
  infisical export --env="$INFISICAL_ENV_SLUG" --path="$1" --projectId="$2" \
    --token="$INFISICAL_TOKEN" --format=dotenv --domain="$INFISICAL_DOMAIN" --silent
}

APP_ENV=$(mktemp)
trap 'rm -f "$APP_ENV"' EXIT
export_dotenv "${INFISICAL_SECRETS_PATH:-/}" "$INFISICAL_PROJECT_ID" >"$APP_ENV"
set -a
# shellcheck disable=SC1090
source "$APP_ENV"
set +a

if [ -n "${DOCR_PASSWORD:-}" ] && [ -n "${DOCR_USERNAME:-}" ]; then
  REGISTRY_PASSWORD="$DOCR_PASSWORD"
else
  BOOTSTRAP_ENV=$(mktemp)
  export_dotenv "$INFISICAL_BOOTSTRAP_PATH" "$INFISICAL_INFRA_PROJECT_ID" >"$BOOTSTRAP_ENV"
  set -a
  # shellcheck disable=SC1090
  source "$BOOTSTRAP_ENV"
  set +a
  rm -f "$BOOTSTRAP_ENV"
  REGISTRY_PASSWORD="${DOCR_PASSWORD:-}"
  DOCR_USERNAME="${DOCR_USERNAME:-}"
fi

for key in AUTH_SECRET KEYCLOAK_CLIENT_SECRET KEYCLOAK_URL KEYCLOAK_REALM KEYCLOAK_CLIENT_ID KEYCLOAK_AUDIENCE KEYCLOAK_OIDC_SCOPE AUTH_URL APP_BASE_URL; do
  eval "val=\${$key:-}"
  [ -n "$val" ] || { echo "Missing $key" >&2; exit 1; }
  printf '%s=%s\n' "$key" "$val"
done

[ -n "${OPENAI_API_KEY:-}" ] && printf 'OPENAI_API_KEY=%s\n' "$OPENAI_API_KEY"
[ -n "${CHAT_MODEL:-}" ] && printf 'CHAT_MODEL=%s\n' "$CHAT_MODEL"

printf 'REGISTRY_PASSWORD=%s\n' "$REGISTRY_PASSWORD"
printf 'DOCR_USERNAME=%s\n' "$DOCR_USERNAME"

if [ -n "${PUBLIC_HOST:-}" ]; then
  printf 'PUBLIC_HOST=%s\n' "$PUBLIC_HOST"
  printf 'NEXT_PUBLIC_GRAPHQL_ENDPOINT=https://%s/api/graphql\n' "$PUBLIC_HOST"
  printf 'NEXT_PUBLIC_MCP_SERVER_URL=https://%s/mcp\n' "$PUBLIC_HOST"
  printf 'APP_BASE_URL=https://%s\n' "$PUBLIC_HOST"
  printf 'AUTH_URL=https://%s\n' "$PUBLIC_HOST"
fi
