#!/usr/bin/env bash
set -euo pipefail

# Emit KEY='value' so `source .kamal/secrets` survives special chars (Pulumi AUTH_SECRET, etc.).
emit_secret() {
  local key=$1 val=$2
  local escaped=${val//\'/\'\\\'\'}
  printf "%s='%s'\n" "$key" "$escaped"
}

INFISICAL_DOMAIN="${INFISICAL_API_URL%/api}"
INFISICAL_ENV_SLUG="${INFISICAL_ENV:-dev}"

export_dotenv() {
  infisical export --env="$INFISICAL_ENV_SLUG" --path="$1" --projectId="$2" \
    --token="$INFISICAL_TOKEN" --format=dotenv --domain="$INFISICAL_DOMAIN" --silent
}

APP_ENV=$(mktemp)
trap 'rm -f "$APP_ENV"' EXIT
export_dotenv "${INFISICAL_SECRETS_PATH:-/}" "$INFISICAL_PROJECT_ID" >"$APP_ENV"
set -a
# shellcheck disable=SC1090
source "$APP_ENV"
set +a

if [ -n "${DOCR_PASSWORD:-}" ] && [ -n "${DOCR_USERNAME:-}" ]; then
  REGISTRY_PASSWORD="$DOCR_PASSWORD"
else
  BOOTSTRAP_ENV=$(mktemp)
  export_dotenv "$INFISICAL_BOOTSTRAP_PATH" "$INFISICAL_INFRA_PROJECT_ID" >"$BOOTSTRAP_ENV"
  set -a
  # shellcheck disable=SC1090
  source "$BOOTSTRAP_ENV"
  set +a
  rm -f "$BOOTSTRAP_ENV"
  REGISTRY_PASSWORD="${DOCR_PASSWORD:-}"
  DOCR_USERNAME="${DOCR_USERNAME:-}"
fi

# Kamal env.secret keys only (non-secrets live in config/deploy.yml env.clear)
for key in AUTH_SECRET KEYCLOAK_CLIENT_SECRET; do
  eval "val=\${$key:-}"
  [ -n "$val" ] || { echo "Missing $key in Infisical (avcd-web)" >&2; exit 1; }
  emit_secret "$key" "$val"
done

[ -n "${OPENAI_API_KEY:-}" ] && emit_secret OPENAI_API_KEY "$OPENAI_API_KEY"

emit_secret REGISTRY_PASSWORD "$REGISTRY_PASSWORD"
emit_secret DOCR_USERNAME "$DOCR_USERNAME"
