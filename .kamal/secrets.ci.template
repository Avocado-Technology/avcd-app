#!/usr/bin/env bash
set -euo pipefail

INFISICAL_DOMAIN="${INFISICAL_API_URL%/api}"

export_dotenv() {
  infisical export --env=dev --path="$1" --projectId="$2" \
    --token="$INFISICAL_TOKEN" --format=dotenv --domain="$INFISICAL_DOMAIN" --silent
}

read_secret() {
  printf '%s\n' "$1" | sed -n "s/^${2}=//p" | head -1
}

BOOTSTRAP_EXPORT=$(export_dotenv "$INFISICAL_BOOTSTRAP_PATH" "$INFISICAL_INFRA_PROJECT_ID")
APP_EXPORT=$(export_dotenv "$INFISICAL_SECRETS_PATH" "$INFISICAL_PROJECT_ID")

REGISTRY_PASSWORD=$(read_secret "$BOOTSTRAP_EXPORT" "DOCR_PASSWORD")
DOCR_USERNAME=$(read_secret "$BOOTSTRAP_EXPORT" "DOCR_USERNAME")

for key in AUTH_SECRET KEYCLOAK_CLIENT_SECRET KEYCLOAK_URL KEYCLOAK_REALM KEYCLOAK_CLIENT_ID KEYCLOAK_AUDIENCE KEYCLOAK_OIDC_SCOPE AUTH_URL APP_BASE_URL; do
  val=$(read_secret "$APP_EXPORT" "$key")
  [ -n "$val" ] || { echo "Missing $key" >&2; exit 1; }
  printf '%s=%s\n' "$key" "$val"
done

OPENAI=$(read_secret "$APP_EXPORT" "OPENAI_API_KEY")
[ -n "$OPENAI" ] && printf 'OPENAI_API_KEY=%s\n' "$OPENAI"

printf 'REGISTRY_PASSWORD=%s\n' "$REGISTRY_PASSWORD"
printf 'DOCR_USERNAME=%s\n' "$DOCR_USERNAME"
