# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files with secrets - DO NOT COMMIT
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.dev
.env.prod
.env.staging
.compose.ci.env

# Backup files from scripts
*.env.backup
.env.*.backup
.env.local.backup

# Allow template files (no secrets) - these SHOULD be committed
!.env.example
!.env.template

# Secret documentation (contains actual client IDs/secrets)
GET_CLIENT_SECRET.md
*SECRET*.md
*CREDENTIALS*.md

# Temporary documentation/summary files (may reference secrets)
AUTH_FIX_SUMMARY.md
DESIGN_SYSTEM_REFACTOR.md
REFACTOR_SUMMARY.md
VERIFICATION_REPORT.md
FINAL_VERIFICATION.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
