# ============================================
# Local Development Secrets (TEMPLATE)
# Copy to .env.local and fill in values.
# NEVER commit .env.local to git.
# ============================================

# --------------------------------------------
# Auth0 Configuration (v4 SDK)
# Get values: cd ../infra && terraform output
# --------------------------------------------

# Session encryption (generate: openssl rand -base64 32)
AUTH0_SECRET=

APP_BASE_URL=http://localhost:3000

# Tenant hostname only, no https:// (e.g. your-tenant.us.auth0.com)
AUTH0_DOMAIN=

AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

AUTH0_AUDIENCE=https://dev.avcd.ai/mcp

AUTH0_SCOPE=openid profile email offline_access

# --------------------------------------------
# API keys (server-only)
# --------------------------------------------

OPENAI_API_KEY=

# --------------------------------------------
# Optional overrides (uncomment to override .env)
# --------------------------------------------

# NEXT_PUBLIC_AVCD_API_URL=https://dev.avcd.ai/api
# NEXT_PUBLIC_MCP_SERVER_URL=https://dev.avcd.ai/mcp
