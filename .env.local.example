# ============================================
# Local Development Secrets (TEMPLATE)
# Copy to .env.local and fill in values.
# NEVER commit .env.local to git.
# ============================================

# --------------------------------------------
# Keycloak / Auth.js Configuration
# Local Keycloak: cd ../keycloak && make up
# --------------------------------------------

# Session encryption (generate: openssl rand -base64 32)
AUTH_SECRET=

APP_BASE_URL=http://localhost:3000

# Keycloak base URL (no trailing slash)
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=avcd

# Web OIDC client (from keycloak/config/avcd-realm.json — avcd-web)
KEYCLOAK_CLIENT_ID=avcd-web
KEYCLOAK_CLIENT_SECRET=local-web-client-secret

# GraphQL API audience (must match API KEYCLOAK_AUDIENCE)
KEYCLOAK_AUDIENCE=https://dev.avcd.ai/api

# --------------------------------------------
# API keys (server-only)
# --------------------------------------------

OPENAI_API_KEY=

# --------------------------------------------
# Optional overrides (uncomment to override .env)
# --------------------------------------------

# NEXT_PUBLIC_AVCD_API_URL=https://dev.avcd.ai/api
# NEXT_PUBLIC_MCP_SERVER_URL=https://dev.avcd.ai/mcp
