# ============================================
# Public Environment Defaults (NON-SENSITIVE)
# Safe to commit — no API keys or Auth0 secrets.
# Copy .env.local.example → .env.local for secrets.
# ============================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=AVCD

# Public URLs (browser)
NEXT_PUBLIC_AVCD_API_URL=http://localhost:8000
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:8000/mcp
NEXT_PUBLIC_PROFILE_ROUTE=/api/auth/profile

# MCP native client id (public when set)
NEXT_PUBLIC_AUTH0_MCP_CLIENT_ID=

# Feature flags
NEXT_PUBLIC_FINANCE_DATA_SOURCE=mock

# Server-side defaults for local `npm run dev` (Docker overrides in docker-compose.yml)
AVCD_API_URL=http://localhost:8000
AVCD_AUTH_URL=http://localhost:8010
AVCD_MCP_URL=http://localhost:5001/mcp
PUBLIC_HOST=localhost
CHAT_MODEL=gpt-4o

# Docker file watching (Compose also sets this explicitly)
WATCHPACK_POLLING=true
